# OpenRouter API key for LLM scoring
OPENROUTER_API_KEY=sk-or-...

# GitHub personal access token
GITHUB_TOKEN=ghp_...

# Target repository (owner/repo)
GITHUB_REPO=owner/repo

# On-chain service URL
ONCHAIN_SERVICE_URL=http://localhost:3001

# Stored permissions context (set after owner signs ERC-7715 permission)
PERMISSIONS_CONTEXT=

# Budget
BUDGET_USDC=500
PERIOD_DAYS=30

# Scheduler
SCHEDULER_INTERVAL_MINUTES=10080
